root = true

[*.{kt,kts}]
# Composable functions use PascalCase by official Compose convention.
ktlint_function_naming_ignore_when_annotated_with = Composable
# Align ktlint's line-length awareness with detekt's MaxLineLength (120) so
# both agree on when an expression body must wrap onto its own line.
max_line_length = 120
